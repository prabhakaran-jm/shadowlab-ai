# DigitalOcean Gradient™ AI – Serverless Inference (optional)
# Enables AI-generated attacks and vulnerability analysis.
# Get the key from: Control Panel → Gradient AI Platform → Serverless Inference → Model Access Keys
# Any of these env vars work (same value):
# MODEL_ACCESS_KEY=          # used in official Gradient SDK docs
# GRADIENT_MODEL_ACCESS_KEY=
# GRADIENT_API_KEY=
GRADIENT_MODEL_ACCESS_KEY=

# Base URL (default: Serverless Inference API)
GRADIENT_API_URL=https://inference.do-ai.run
# Prompt generation: lightweight, fast (default: openai-gpt-oss-20b)
# GRADIENT_MODEL_GENERATION=openai-gpt-oss-20b
# Failure analysis: stronger model for reasoning (default: llama3.3-70b-instruct)
# GRADIENT_MODEL_ANALYSIS=llama3.3-70b-instruct
